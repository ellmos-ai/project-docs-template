TODAY = date.today().isoformat()
DEFAULT_VERSION = "0.1.0"

# Files die gescannt werden + deren erwartetes Schema
FILE_SCHEMAS = {
    "CLAUDE.md": {
        "type": "project-docs",
        "required": [
            "name", "type", "version", "created", "updated",
            "reason_last_change",
            "last_verified", "description"
        ],
        "optional": ["profile", "author", "anthropic_compatible"],
        "field_order": [
            "name", "type", "profile", "version", "created", "updated",
            "reason_last_change",
            "last_verified", "author", "anthropic_compatible", "description"
        ],
    },
    "START.md": {
        "type": "session-bootstrap",
        "required": ["name", "type", "version", "updated", "last_verified"],
        "optional": ["description"],
        "field_order": [
            "name", "type", "version", "updated", "last_verified", "description"
        ],
    },
    "STATE.md": {
        "type": "state-snapshot",
        "required": ["name", "type", "updated", "updated_by", "current_phase"],
