    },
}

MAX_AGE_DEFAULT = 30  # Tage


def _is_placeholder_value(value) -> bool:
    return isinstance(value, str) and value.startswith("[") and value.endswith("]")


def _value_or_default(value, default):
    if value is None or value == "" or _is_placeholder_value(value):
        return default
    return value


def is_template_source_root(root: Path) -> bool:
    """True nur für das kanonische project-docs-Quelltemplate."""
    return (
        (root / "TEMPLATE.md").exists()
        and (root / "_tools" / "init-project").exists()
        and (root / "CLAUDE.md").exists()
    )


# ============================================================================
# YAML-FRONTMATTER PARSER (adaptiert von BACH skill_header_gen.py:121)
# ============================================================================

class FrontmatterParseError(ValueError):
    """Raised when an existing YAML header cannot be parsed safely."""


def parse_yaml_frontmatter(content: str) -> tuple[dict, str, bool]:
    """Parse YAML frontmatter from markdown content.

    Returns:
        (yaml_dict, body_text, had_frontmatter)
    """
    content = content.lstrip("\ufeff")  # strip BOM
    lines = content.split("\n")

    if not lines or lines[0].strip() != "---":
        return {}, content, False

    end_idx = None
    for i in range(1, len(lines)):
        if lines[i].strip() == "---":
            end_idx = i
            break

    if end_idx is None:
        return {}, content, False

    yaml_text = "\n".join(lines[1:end_idx])
    body_text = "\n".join(lines[end_idx + 1:])

    if HAS_YAML:
        try:
            data = yaml.safe_load(yaml_text) or {}
        except yaml.YAMLError as e:
            raise FrontmatterParseError(f"YAML kann nicht sicher geparst werden: {e}") from e
    else:
        # Fallback: naive regex-based parser (nur flache key:value + |-blöcke)
        data = _naive_yaml_parse(yaml_text)

    if not isinstance(data, dict):
        raise FrontmatterParseError("YAML-Frontmatter muss ein Mapping sein")

    return data, body_text, True


def _naive_yaml_parse(yaml_text: str) -> dict:
    """Fallback-Parser ohne PyYAML — nur flache Strukturen + multi-line |."""
    result = {}
    current_key = None
    current_multi = []

    for raw_line in yaml_text.split("\n"):
        line = raw_line.rstrip()
        if not line.strip():
            continue

        # Multi-line continuation
        if current_key and line.startswith("  "):
            current_multi.append(line[2:])
            continue

        # Finish previous multi-line
        if current_key and current_multi:
            result[current_key] = "\n".join(current_multi).strip()
            current_key = None
            current_multi = []

        if ":" in line and not line.startswith(" "):
            key, _, value = line.partition(":")
            key = key.strip()
            value = value.strip()
            if value == "|" or value == ">":
                current_key = key
                current_multi = []
            else:
                if value.startswith('"') or value.endswith('"'):
                    if not (value.startswith('"') and value.endswith('"')):
                        raise FrontmatterParseError(f"Ungültiger quoted scalar: {line}")
                    try:
                        value = json.loads(value)
                    except json.JSONDecodeError as exc:
                        raise FrontmatterParseError(
                            f"Ungültiger double-quoted scalar: {line}"
                        ) from exc
                elif value.startswith("'") or value.endswith("'"):
                    if not (value.startswith("'") and value.endswith("'")):
                        raise FrontmatterParseError(f"Ungültiger quoted scalar: {line}")
                    value = value[1:-1].replace("''", "'")
                # Type coercion for booleans
                if value.lower() == "true":
                    value = True
                elif value.lower() == "false":
                    value = False
                result[key] = value
        elif not line.lstrip().startswith("#"):
            raise FrontmatterParseError(f"Ungültige YAML-Zeile: {line}")

    # Cleanup last multi-line
    if current_key and current_multi:
        result[current_key] = "\n".join(current_multi).strip()

    return result


# ============================================================================
# HEADER NORMALIZATION (adaptiert von BACH skill_header_gen.py:161)
# ============================================================================

def normalize_header(data: dict, file_path: Path, schema: dict) -> dict:
    """Normalize a parsed YAML header to the standard format.

    - Fügt fehlende Pflichtfelder mit Defaults ein
    - Behält existierende Werte (überschreibt nicht)
    - Ordnet Felder in field_order-Reihenfolge
    """
    normalized = {}

    # Detect defaults
    detected_name = _detect_name(file_path)
    detected_type = schema["type"]

    # Fülle Felder in der Standard-Reihenfolge
    for field in schema["field_order"]:
        if field == "name":
            normalized[field] = _value_or_default(data.get("name"), detected_name)
        elif field == "type":
            normalized[field] = _value_or_default(data.get("type"), detected_type)
        elif field == "version":
            normalized[field] = str(_value_or_default(data.get("version"), DEFAULT_VERSION))
        elif field == "profile":
            if "profile" in data and data["profile"] and not _is_placeholder_value(data["profile"]):
                normalized[field] = data["profile"]
            # sonst: optional, nicht einfügen
        elif field == "created":
            normalized[field] = str(_value_or_default(data.get("created"), TODAY))
        elif field == "updated":
            normalized[field] = str(_value_or_default(data.get("updated"), TODAY))
        elif field == "reason_last_change":
            normalized[field] = _value_or_default(
                data.get("reason_last_change"), "Dokumentation normalisiert"
            )
        elif field == "last_verified":
            normalized[field] = str(_value_or_default(data.get("last_verified"), TODAY))
        elif field == "updated_by":
            normalized[field] = _value_or_default(data.get("updated_by"), "doc-lint")
        elif field == "current_phase":
            normalized[field] = _value_or_default(data.get("current_phase"), "Initial Setup")
        elif field == "author":
            if "author" in data and data["author"] and not _is_placeholder_value(data["author"]):
                normalized[field] = data["author"]
            # sonst: optional
        elif field == "anthropic_compatible":
            normalized[field] = data.get("anthropic_compatible", True)
        elif field == "description":
            description = data.get("description", "")
            normalized[field] = _value_or_default(
                description.strip() if isinstance(description, str) else description,
                "Projekt-Dokumentation",
            )

    # Projekt- oder Tool-spezifische Erweiterungen sind Daten, keine Fehler.
    # Sie bleiben nach den kanonischen Feldern in ihrer Originalreihenfolge.
    for field, value in data.items():
        if field not in schema["field_order"]:
            normalized[field] = value

    return normalized


def _detect_name(file_path: Path) -> str:
    """Detect project-name from parent directory."""
    # Für CLAUDE.md im project-root: parent dir name
    parent = file_path.resolve().parent.name
    if file_path.name == "CLAUDE.md":
        return parent
    # Für STATE.md / START.md: parent dir + "-state"/"-start" Suffix
    stem_lower = file_path.stem.lower()
    return f"{parent}-{stem_lower}"


# ============================================================================
# HEADER GENERATION aus Content (adaptiert von BACH:231)
# ============================================================================

def generate_header_from_content(content: str, file_path: Path, schema: dict) -> dict:
    """Bootstrap: Wenn kein YAML-Header da ist, baue einen aus Content-Hints."""
    header = {
        "name": _detect_name(file_path),
        "type": schema["type"],
        "version": DEFAULT_VERSION,
        "created": TODAY,
        "updated": TODAY,
        "last_verified": TODAY,
        "description": "Projekt-Dokumentation",
    }

    if schema["type"] == "project-docs":
        header["reason_last_change"] = "Frontmatter mit doc-lint ergänzt"

    # Description aus erster Prose-Zeile nach H1 oder Blockquote
    lines = content.strip().split("\n")
    desc_lines = []
    in_desc = False

    for line in lines:
        stripped = line.strip()
        if stripped.startswith("#"):
            if in_desc:
                break
            continue
        if not stripped and not in_desc:
            continue
        if stripped.startswith(("```", "---", "|")):
            if in_desc:
                break
            continue
        if stripped.startswith(">"):
            desc_text = stripped.lstrip("> ").strip()
            if desc_text and len(desc_text) > 10:
                desc_lines.append(desc_text)
                in_desc = True
            continue
        if stripped:
            desc_lines.append(stripped)
            in_desc = True
        elif in_desc:
            break

    if desc_lines:
        header["description"] = " ".join(desc_lines)[:300]

    # Version aus Content (falls dort erwähnt)
    version_match = re.search(
        r"(?:Version|version|VERSION)[:\s]+v?(\d+\.\d+(?:\.\d+)?)",
        content,
    )
    if version_match:
        header["version"] = version_match.group(1)

    # Type-specific extras
    if schema["type"] == "state-snapshot":
        header["updated_by"] = "doc-lint"
        header["current_phase"] = "Initial Setup"

    return header


# ============================================================================
# HEADER RENDERER (adaptiert von BACH skill_header_gen.py:299)
# ============================================================================

def render_yaml_header(data: dict, schema: dict) -> str:
    """Render header dict as YAML frontmatter string in standard order."""
    lines = ["---"]

    ordered_fields = list(schema["field_order"])
    ordered_fields.extend(field for field in data if field not in ordered_fields)

    for field in ordered_fields:
        if field not in data:
            continue
        value = data[field]

        if isinstance(value, bool):
            lines.append(f"{field}: {str(value).lower()}")
        elif isinstance(value, str):
            # JSON-Strings sind gültige YAML-Scalars und schützen Doppelpunkte,
            # Hashes, Quotes sowie bool-artige Wörter zuverlässig.
            lines.append(f"{field}: {json.dumps(str(value), ensure_ascii=False)}")
        else:
            lines.append(
                f"{field}: {json.dumps(value, ensure_ascii=False, default=str)}"
            )

    lines.append("---")
    return "\n".join(lines)


def atomic_write_text(path: Path, content: str) -> None:
    """Write UTF-8 text via a same-directory temporary file and replace."""
    path.parent.mkdir(parents=True, exist_ok=True)
    fd, temp_name = tempfile.mkstemp(prefix=f".{path.name}.", dir=path.parent)
    temp_path = Path(temp_name)
    try:
        with os.fdopen(fd, "w", encoding="utf-8", newline="\n") as handle:
            handle.write(content)
            handle.flush()
            os.fsync(handle.fileno())
        os.replace(temp_path, path)
    finally:
        temp_path.unlink(missing_ok=True)


# ============================================================================
# LINT-LOGIK
# ============================================================================

class LintResult:
    def __init__(self, filename: str):
        self.filename = filename
        self.errors: list[str] = []
        self.warnings: list[str] = []
        self.file_path: Path | None = None
        self.parsed_header: dict = {}
        self.body: str = ""
        self.had_frontmatter: bool = False

    def add_error(self, msg: str) -> None:
        self.errors.append(msg)

    def add_warning(self, msg: str) -> None:
        self.warnings.append(msg)

    def has_errors(self) -> bool:
        return bool(self.errors)

    def print_report(self) -> None:
        if not self.errors and not self.warnings:
            print(f"  OK   {self.filename}")
            return
        for err in self.errors:
            print(f"  FAIL {self.filename}: {err}")
        for warn in self.warnings:
            print(f"  WARN {self.filename}: {warn}")


def check_staleness(fm: dict, max_age: int) -> tuple[bool, int]:
    """Returns (is_stale, age_in_days)."""
    lv = str(fm.get("last_verified", ""))
    if not lv or lv.startswith("["):
        return True, -1

    try:
        lv_date = datetime.strptime(lv, "%Y-%m-%d").date()
    except ValueError:
        return True, -1

    age = (date.today() - lv_date).days
    return age > max_age, age


def lint_file(
    path: Path,
    schema: dict,
    max_age: int,
    allow_template_placeholders: bool = False,
) -> LintResult:
    """Lintet ein einzelnes File."""
    result = LintResult(path.name)
    result.file_path = path

    if not path.exists():
        result.add_warning("File existiert nicht (optional?)")
        return result

    content = path.read_text(encoding="utf-8")
    try:
        fm, body, had_fm = parse_yaml_frontmatter(content)
    except FrontmatterParseError as exc:
        result.add_error(str(exc))
        return result
    result.parsed_header = fm
    result.body = body
    result.had_frontmatter = had_fm

    if not had_fm:
        result.add_error("Kein YAML-Frontmatter gefunden")
        return result

    # Type-Check
    expected_type = schema["type"]
    actual_type = fm.get("type", "")
    if actual_type != expected_type:
        result.add_error(
            f"type-Mismatch: erwartet '{expected_type}', gefunden '{actual_type or '(fehlt)'}'"
        )

    # Pflichtfelder prüfen
    missing = []
    for field in schema["required"]:
        value = fm.get(field)
        if value is None or value == "":
            missing.append(field)
            continue
        if _is_placeholder_value(value) and not allow_template_placeholders:
            missing.append(field)
    if missing:
        result.add_error(f"Pflichtfelder fehlen/Platzhalter: {', '.join(missing)}")

    placeholder_fields = [
        key for key, value in fm.items()
        if _is_placeholder_value(value)
        and key not in missing
        and not allow_template_placeholders
    ]
    if placeholder_fields:
        result.add_error(
            "Frontmatter-Platzhalter nicht aufgelöst: "
            + ", ".join(sorted(placeholder_fields))
        )

    # Staleness
    if not (allow_template_placeholders and _is_placeholder_value(fm.get("last_verified"))):
        is_stale, age = check_staleness(fm, max_age)
        if is_stale:
            if age == -1:
                result.add_warning("last_verified ist nicht gesetzt oder ungültig")
            else:
                result.add_warning(
                    f"last_verified ist {age} Tage alt (max: {max_age})"
                )

    return result


def fix_file(path: Path, schema: dict, update_dates: bool, dry_run: bool = False) -> bool:
    """Repariert ein File: fügt fehlende Felder ein, sortiert, schreibt zurück.

    Returns True wenn etwas geändert wurde.
    """
    if not path.exists():
        print(f"  SKIP {path.name}: existiert nicht")
        return False

    content = path.read_text(encoding="utf-8")
    try:
        fm, body, had_fm = parse_yaml_frontmatter(content)
    except FrontmatterParseError as exc:
        print(f"  SKIP {path.name}: {exc}")
        return False

    if not had_fm:
        # Auto-generate from content
        print(f"  FIX  {path.name}: generiere frischen Header aus Content")
        fm = generate_header_from_content(content, path, schema)
        body = content  # gesamter alter content wird zum body

    # Normalize (fehlende Felder einfügen)
    normalized = normalize_header(fm, path, schema)

    # Dates updaten falls gewünscht
    if update_dates:
        normalized["updated"] = TODAY
        if "last_verified" in normalized:
            normalized["last_verified"] = TODAY

    # Neuen Header rendern
    new_header = render_yaml_header(normalized, schema)

    # Zusammenbauen
    if body and not body.startswith("\n"):
        new_content = new_header + "\n\n" + body.lstrip()
    else:
        new_content = new_header + body

    # Prüfe ob Änderung nötig
    if new_content == content:
        print(f"  OK   {path.name}: keine Änderung nötig")
        return False

    if dry_run:
        print(f"  [DRY] {path.name}: würde aktualisiert werden")
        return True

    # Schreiben
    atomic_write_text(path, new_content)
    print(f"  FIX  {path.name}: Header aktualisiert")
    return True


# ============================================================================
# CLI
# ============================================================================

def main():
    parser = argparse.ArgumentParser(
        description="Lint YAML-Frontmatter in project docs",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__,
    )
    parser.add_argument("--file", type=Path, help="Nur dieses File prüfen")
    parser.add_argument("--fix", action="store_true", help="Fehlende Felder einfügen")
    parser.add_argument("--update-dates", action="store_true",
                        help="updated + last_verified auf heute setzen")
    parser.add_argument("--dry-run", action="store_true",
                        help="Zeigt --fix Plan ohne zu schreiben")
    parser.add_argument("--max-age", type=int, default=MAX_AGE_DEFAULT,
                        help=f"Staleness-Threshold in Tagen (default: {MAX_AGE_DEFAULT})")
    parser.add_argument("--strict", action="store_true",
                        help="Exit != 0 auch bei Warnings")
    parser.add_argument("--root", type=Path, default=Path.cwd(),
                        help="Projekt-Root (default: cwd)")
    args = parser.parse_args()
    template_source_mode = is_template_source_root(args.root.resolve())

    if not HAS_YAML:
        print("[INFO] PyYAML nicht installiert — nutze Fallback-Parser "
              "(funktioniert für einfache Fälle)", file=sys.stderr)

    print(f"==> Root:    {args.root.resolve()}")
    print(f"==> Max age: {args.max_age} days")
    if template_source_mode:
        print("==> Mode:    template-source (Platzhalter in Meta-Files erlaubt)")
    if args.fix:
        print(f"==> Mode:    FIX {'(dry-run)' if args.dry_run else ''}")
    if args.update_dates:
        print(f"==> Dates:   will update updated + last_verified")
    print()

    results: list[LintResult] = []

    if args.file:
        filename = args.file.name
        schema = FILE_SCHEMAS.get(filename)
        if not schema:
            print(f"ERROR: Kein Schema für '{filename}'", file=sys.stderr)
            print(f"Verfügbar: {', '.join(FILE_SCHEMAS.keys())}", file=sys.stderr)
            sys.exit(2)
        path = args.file if args.file.is_absolute() else args.root / args.file
        result = lint_file(
            path,
            schema,
            args.max_age,
            allow_template_placeholders=template_source_mode,
        )
        results.append(result)
    else:
        for filename, schema in FILE_SCHEMAS.items():
            path = args.root / filename
            result = lint_file(
                path,
                schema,
                args.max_age,
                allow_template_placeholders=template_source_mode,
            )
            results.append(result)

    # Lint-Report
    print("Results:")
    for r in results:
        r.print_report()

    # Fix-Pass
    if args.fix or args.update_dates:
        print("\n==> Fixing...")
        for r in results:
            if not r.file_path:
                continue
            schema = FILE_SCHEMAS.get(r.filename)
            if not schema:
                continue
            # Fix wenn Errors da sind ODER update_dates verlangt
            if r.has_errors() or args.update_dates or not r.had_frontmatter:
                fix_file(r.file_path, schema, args.update_dates, args.dry_run)

        # Ein Fix ist nur erfolgreich, wenn der tatsächlich geschriebene Stand
        # den gleichen Vertrag anschließend erfüllt.
        if not args.dry_run:
            print("\n==> Re-checking...")
            refreshed: list[LintResult] = []
            for r in results:
                if not r.file_path:
                    continue
                schema = FILE_SCHEMAS.get(r.filename)
                if schema:
                    refreshed.append(lint_file(
                        r.file_path,
                        schema,
                        args.max_age,
                        allow_template_placeholders=template_source_mode,
                    ))
            results = refreshed
            for r in results:
                r.print_report()

    # Exit-Code
    any_errors = any(r.has_errors() for r in results)
    any_warnings = any(r.warnings for r in results)

    print()
    if any_errors:
        print("FAIL: Dokumentationsvertrag ist nicht erfüllt")
        sys.exit(1)
    if args.strict and any_warnings:
        print("FAIL (strict): Warnings gefunden")
        sys.exit(1)

    print("OK: Alle geprüften Files bestehen (oder wurden gefixt)")
    sys.exit(0)


if __name__ == "__main__":
    main()
